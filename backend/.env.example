APP_NAME=US RealView API
CORS_ORIGINS=http://localhost:3000
REFRESH_INTERVAL_SECONDS=60
REPLAY_RETENTION_HOURS=24
USE_LIVE_FEEDS=true
DEFAULT_LAT=32.7767
DEFAULT_LON=-96.7970
NWS_USER_AGENT=USRealView/1.0 (local demo)

DALLAS_TRAFFIC_URL=https://www.dallasopendata.com/resource/tqs9-xfzb.json?$$limit=200
DALLAS_INCIDENTS_URL=https://www.dallasopendata.com/resource/qv6i-rri7.json?$$limit=200&$$where=geocoded_column%20IS%20NOT%20NULL&$$order=reporteddate%20DESC
DALLAS_CRIMES_URL=https://www.dallasopendata.com/resource/pumt-d92b.json?$$limit=200&$$order=offensedate%20DESC
